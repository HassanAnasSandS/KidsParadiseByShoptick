<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KidsParadiseByShoptick.AdminApp.Models"
             xmlns:vm="clr-namespace:KidsParadiseByShoptick.AdminApp.ViewModels"
             x:Class="KidsParadiseByShoptick.AdminApp.Views.NotificationsPage"
             x:Name="ThisPage"
             x:DataType="vm:NotificationsViewModel"
             Title="Order Alerts"
             BackgroundColor="{StaticResource PageBg}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <!-- Status card -->
            <Frame Padding="16" CornerRadius="16" BorderColor="#e2e8f0" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Order Notifications" FontSize="18" FontAttributes="Bold" TextColor="#0f172a" />
                    <HorizontalStackLayout Spacing="8">
                        <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                 Color="{Binding IsListening, Converter={StaticResource ListeningColor}}" VerticalOptions="Center" />
                        <Label Text="{Binding StatusText}" FontSize="14" TextColor="#334155" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding ConnectionInfo}" FontSize="12" TextColor="#64748b" />
                    <Label Text="{Binding UnreadCount, StringFormat='{0} unread'}" FontSize="12" TextColor="#1a6fe8"
                           IsVisible="{Binding UnreadCount, Converter={StaticResource IntToBool}}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Enable order alerts" VerticalOptions="Center" FontSize="14" />
                        <Switch Grid.Column="1" IsToggled="{Binding NotificationsEnabled}" OnColor="#1a6fe8" />
                    </Grid>

                    <Button Text="Allow phone notifications" Command="{Binding RequestPermissionCommand}"
                            BackgroundColor="#64748b" TextColor="White" CornerRadius="10" />
                    <Button Text="Send test notification" Command="{Binding TestNotificationCommand}"
                            BackgroundColor="#1a6fe8" TextColor="White" CornerRadius="10" />
                    <Button Text="Open Orders" Command="{Binding OpenOrdersCommand}"
                            BackgroundColor="#0f172a" TextColor="White" CornerRadius="10" />
                </VerticalStackLayout>
            </Frame>

            <!-- History header -->
            <Grid ColumnDefinitions="*,Auto,Auto">
                <Label Grid.Column="0" Text="Recent alerts" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="Read all" FontSize="12" Padding="8,4" Command="{Binding MarkAllReadCommand}" />
                <Button Grid.Column="2" Text="Clear" FontSize="12" Padding="8,4" BackgroundColor="#dc2626" TextColor="White"
                        Command="{Binding ClearHistoryCommand}" />
            </Grid>

            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" HorizontalOptions="Center">
                        <Label Text="🔔" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="No order alerts yet" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#64748b" />
                        <Label Text="When a customer places an order, it will appear here and as a phone notification."
                               FontSize="13" TextColor="#94a3b8" HorizontalTextAlignment="Center" Margin="0,8,0,0" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:OrderNotificationItem">
                        <Frame Margin="0,4" Padding="14" CornerRadius="14" BorderColor="#e2e8f0" BackgroundColor="White">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.OpenItemCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Title}" FontAttributes="Bold" TextColor="#0f172a" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding TimeLabel}" FontSize="11" TextColor="#94a3b8" />
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Preview}" FontSize="13"
                                       TextColor="#475569" Margin="0,6,0,0" LineBreakMode="TailTruncation" MaxLines="3" />
                                <Label Grid.Row="2" Grid.Column="0" Text="NEW" FontSize="10" TextColor="#1a6fe8" FontAttributes="Bold"
                                       Margin="0,6,0,0" IsVisible="{Binding IsRead, Converter={StaticResource InverseBool}}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
