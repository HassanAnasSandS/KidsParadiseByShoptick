<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KidsParadiseByShoptick.AdminApp.ViewModels"
             x:Class="KidsParadiseByShoptick.AdminApp.Views.ReviewEditPage"
             x:DataType="vm:ReviewEditViewModel"
             Title="Edit Review">
    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="12">
            <Label Text="{Binding ToyName}" FontAttributes="Bold" TextColor="#1a6fe8" />
            <Entry Placeholder="Reviewer name" Text="{Binding ReviewerName}" />
            <Picker Title="Rating" ItemsSource="{Binding RatingOptions}" SelectedItem="{Binding Rating}" />
            <Editor Placeholder="Comment" Text="{Binding Comment}" AutoSize="TextChanges" MinimumHeightRequest="100" />
            <Image Source="{Binding ImageUrl, Converter={StaticResource ImageUrl}}" HeightRequest="100" Aspect="AspectFit" IsVisible="{Binding ImageUrl, Converter={StaticResource NullToBool}}" />
            <Button Text="Upload Image" Command="{Binding PickImageCommand}" />
            <Button Text="Remove Image" Command="{Binding RemoveImageCommand}" IsVisible="{Binding ImageUrl, Converter={StaticResource NullToBool}}" />
            <Button Text="Save" Command="{Binding SaveCommand}" BackgroundColor="#1a6fe8" TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
