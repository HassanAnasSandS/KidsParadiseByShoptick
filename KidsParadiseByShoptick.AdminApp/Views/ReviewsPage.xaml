<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KidsParadiseByShoptick.AdminApp.Models"
             xmlns:vm="clr-namespace:KidsParadiseByShoptick.AdminApp.ViewModels"
             x:Class="KidsParadiseByShoptick.AdminApp.Views.ReviewsPage"
             x:Name="ThisPage"
             x:DataType="vm:ReviewsViewModel"
             Title="Reviews"
             BackgroundColor="{StaticResource PageBg}">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh" Command="{Binding LoadCommand}" />
    </ContentPage.ToolbarItems>
    <Grid RowDefinitions="Auto,*" Padding="12">
        <SearchBar Grid.Row="0" Placeholder="Search reviews..." Text="{Binding SearchText}" />
        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ReviewModel">
                        <Frame Margin="0,4" Padding="12" CornerRadius="12" BorderColor="#e2e8f0">
                            <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="8">
                                <Image Grid.Column="0" Source="{Binding ImageUrl, Converter={StaticResource ImageUrl}}" HeightRequest="48" WidthRequest="48" Aspect="AspectFill" />
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="{Binding ReviewerName}" FontAttributes="Bold" />
                                    <Label Text="{Binding ToyName}" FontSize="12" TextColor="#1a6fe8" />
                                    <Label Text="{Binding Rating, StringFormat='Rating: {0}/5'}" FontSize="12" />
                                    <Label Text="{Binding Comment}" FontSize="12" LineBreakMode="TailTruncation" MaxLines="2" />
                                </VerticalStackLayout>
                                <Button Grid.Column="2" Text="Edit" Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.EditCommand}" CommandParameter="{Binding .}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
