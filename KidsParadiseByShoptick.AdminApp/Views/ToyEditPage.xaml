<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KidsParadiseByShoptick.AdminApp.Models"
             xmlns:vm="clr-namespace:KidsParadiseByShoptick.AdminApp.ViewModels"
             x:Class="KidsParadiseByShoptick.AdminApp.Views.ToyEditPage"
             x:Name="ThisPage"
             x:DataType="vm:ToyEditViewModel"
             Title="{Binding Title}">
    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="12">
            <Entry Placeholder="Toy name" Text="{Binding Name}" />
            <Picker Title="Category" ItemsSource="{Binding Categories}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedCategory}" />
            <Entry Placeholder="Price (Rs.)" Keyboard="Numeric" Text="{Binding PriceText}" />
            <Entry Placeholder="Sale price (optional)" Keyboard="Numeric" Text="{Binding SalePriceText}" />

            <Label Text="Video (optional)" FontAttributes="Bold" TextColor="#0f172a" />
            <Label Text="Optional: upload to YouTube and the link is saved with the toy when you tap Save."
                   FontSize="12" TextColor="#64748b" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Button Grid.Column="0" Text="Select video" Command="{Binding PickVideoCommand}"
                        BackgroundColor="#e2e8f0" TextColor="#334155" />
                <Button Grid.Column="1" Text="Clear" Command="{Binding ClearVideoCommand}"
                        BackgroundColor="Transparent" TextColor="#64748b" BorderColor="#cbd5e1" BorderWidth="1" />
            </Grid>
            <Label Text="{Binding SelectedVideoFileName}" FontSize="12" TextColor="#334155"
                   IsVisible="{Binding SelectedVideoFileName, Converter={StaticResource NullToBool}}" />
            <Button Text="Upload to YouTube" Command="{Binding UploadVideoCommand}"
                    IsEnabled="{Binding CanUploadVideo}"
                    BackgroundColor="#dc2626" TextColor="White" />
            <ActivityIndicator IsRunning="{Binding IsUploadingVideo}" IsVisible="{Binding IsUploadingVideo}" Color="#dc2626" />
            <Label Text="{Binding VideoUploadStatus}" FontSize="12" TextColor="#64748b"
                   IsVisible="{Binding VideoUploadStatus, Converter={StaticResource NullToBool}}" />
            <Entry Placeholder="YouTube link (optional, filled after upload)" Text="{Binding VideoLinkText}" IsReadOnly="True"
                   IsVisible="{Binding VideoLinkText, Converter={StaticResource NullToBool}}" />

            <Button Text="Add Images" Command="{Binding PickImagesCommand}" />
            <CollectionView ItemsSource="{Binding Images}" HeightRequest="120">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ToyImageItem">
                        <Grid WidthRequest="90">
                            <Image Source="{Binding Url, Converter={StaticResource ImageUrl}}" HeightRequest="80" Aspect="AspectFit" />
                            <Button Text="×" HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="#dc2626" TextColor="White" FontSize="10" Padding="4"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.RemoveImageCommand}" CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Button Text="Save" Command="{Binding SaveCommand}" BackgroundColor="#1a6fe8" TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
